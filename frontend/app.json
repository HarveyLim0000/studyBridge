{
  "expo": {
    "name": "StudyBridge",
    "slug": "studybridge",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.studybridge.app",
      "infoPlist": {
        "NSCameraUsageDescription": "책의 개념을 촬영해 학술 자료와 연결하기 위해 카메라가 필요합니다."
      }
    },
    "android": {
      "package": "com.studybridge.app",
      "permissions": ["android.permission.CAMERA"]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "책의 개념을 촬영해 학술 자료와 연결하기 위해 카메라가 필요합니다."
        }
      ]
    ]
  }
}
